---
const industries = [
  {
    label: 'Power',
    svg: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <polygon points="28,4 14,26 22,26 20,44 34,22 26,22" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round" fill="none"/>
    </svg>`,
  },
  {
    label: 'Infrastructure',
    svg: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <rect x="6" y="20" width="36" height="22" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round" fill="none"/>
      <polyline points="2,20 24,6 46,20" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round" fill="none"/>
      <rect x="18" y="30" width="12" height="12" stroke="currentColor" stroke-width="2.5" fill="none"/>
    </svg>`,
  },
  {
    label: 'Automotive',
    svg: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M6 30 L10 18 L16 14 L32 14 L38 18 L42 30 L42 36 L6 36 Z" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round" fill="none"/>
      <circle cx="14" cy="36" r="5" stroke="currentColor" stroke-width="2.5" fill="none"/>
      <circle cx="34" cy="36" r="5" stroke="currentColor" stroke-width="2.5" fill="none"/>
      <line x1="16" y1="22" x2="32" y2="22" stroke="currentColor" stroke-width="2.5"/>
    </svg>`,
  },
  {
    label: 'Tyres',
    svg: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <circle cx="24" cy="24" r="19" stroke="currentColor" stroke-width="2.5" fill="none"/>
      <circle cx="24" cy="24" r="9" stroke="currentColor" stroke-width="2.5" fill="none"/>
      <line x1="24" y1="5" x2="24" y2="15" stroke="currentColor" stroke-width="2"/>
      <line x1="24" y1="33" x2="24" y2="43" stroke="currentColor" stroke-width="2"/>
      <line x1="5" y1="24" x2="15" y2="24" stroke="currentColor" stroke-width="2"/>
      <line x1="33" y1="24" x2="43" y2="24" stroke="currentColor" stroke-width="2"/>
    </svg>`,
  },
];
---

<section class="industries">
  <div class="container">
    <p class="industries__label">Industries Served</p>
    <div class="industries__grid">
      {industries.map(ind => (
        <div class="industries__item">
          <div class="industries__icon" set:html={ind.svg} />
          <span class="industries__name">{ind.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .industries {
    background: var(--color-off-white);
    padding-block: 3rem;
    border-bottom: 1px solid rgba(14, 33, 66, 0.08);
  }

  .industries__label {
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-slate);
    margin-bottom: 2rem;
    opacity: 0.7;
  }

  .industries__grid {
    display: flex;
    flex-wrap: wrap;
    gap: 2.5rem;
  }

  .industries__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    min-width: 80px;
  }

  .industries__icon {
    width: 48px;
    height: 48px;
    color: var(--color-navy);
    opacity: 0.75;
  }

  .industries__icon svg {
    width: 100%;
    height: 100%;
  }

  .industries__name {
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-slate);
    letter-spacing: 0.04em;
  }
</style>
